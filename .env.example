# ScreenLens-DGX environment example
#
# Copy to .env. ScreenLens loads .env from the working directory or repository
# root automatically. Shell exports take precedence over this file.
#
# This fork targets NVIDIA DGX Spark only (local vLLM + CUDA).

# ── NVIDIA DGX Spark / vLLM ─────────────────────────────────────────────────
# Used by default and by setup_and_run_dgx.sh. The multimodal Qwen checkpoint
# handles semantic captions, verbatim OCR, and text reconstruction.
#
# Replace the placeholder with a Hugging Face read token before the helper must
# start its own container. A token is not needed merely to reuse an already-ready
# exact-model service owned by DigitalTwin or another local stack.
HF_TOKEN=hf_replace_me
HF_HUB_DISABLE_XET=1

DGX_VENV_DIR=.venv-dgx
DGX_PYTHON_BIN=python3.12
MODEL_HOME=/home/spider/models
DGX_HF_CACHE=/home/spider/models/huggingface
DGX_VLLM_CACHE=/home/spider/models/.cache/vllm

VLLM_IMAGE=vllm/vllm-openai@sha256:e4f88a835143cd22aee2397a26ec6bb80b3a4a6fe0c882bcbc63822904766089
VLLM_MODEL=Qwen/Qwen3.6-27B-FP8
VLLM_MODEL_REVISION=e89b16ebf1988b3d6befa7de50abc2d76f26eb09
VLLM_QUANTIZATION=fp8
VLLM_KV_CACHE_DTYPE=auto
VLLM_BASE_URL=http://127.0.0.1:8000/v1
VLLM_API_KEY=local
VLLM_GPU_MEMORY_UTILIZATION=0.45
VLLM_MAX_MODEL_LEN=262144
VLLM_START_TIMEOUT=1800
VLLM_LOG_TAIL=200

# ── OCR endpoint (defaults to the same canonical Qwen service) ──────────────
# OCR reuses port 8000, avoiding a second model allocation and duplicate cache.
# Override these only when targeting an independently managed OCR endpoint.
#OCR_VLLM_IMAGE=vllm/vllm-openai@sha256:e4f88a835143cd22aee2397a26ec6bb80b3a4a6fe0c882bcbc63822904766089
#OCR_MODEL=Qwen/Qwen3.6-27B-FP8
#OCR_MODEL_REVISION=e89b16ebf1988b3d6befa7de50abc2d76f26eb09
#OCR_BASE_URL=http://127.0.0.1:8000/v1
#OCR_API_KEY=local
#OCR_GPU_MEMORY_UTILIZATION=0.45
#OCR_MAX_MODEL_LEN=262144
#OCR_MAX_NUM_SEQS=2
#OCR_MAX_NUM_BATCHED_TOKENS=8192
#OCR_START_TIMEOUT=900
#OCR_LOG_TAIL=200

# vLLM-specific compatibility aliases are accepted by Python and the helper;
# provider-neutral OCR_* values take precedence when both are set.
#VLLM_OCR_MODEL=Qwen/Qwen3.6-27B-FP8
#VLLM_OCR_BASE_URL=http://127.0.0.1:8000/v1
#VLLM_OCR_API_KEY=local

# setup_and_run_dgx.sh run exports these itself. They are shown here as the
# application-side contract for direct/manual DGX invocations.
#SCREENLENS_BACKEND=vllm
#SCREENLENS_DEVICE=cuda
#SCREENLENS_BATCH_SIZE=2

# ── Ollama fallback backend ────────────────────────────────────────────────
# Used only with --backend ollama.
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2-vision
